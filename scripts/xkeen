            # Перезапуск скрипта
            grep -E "^\s*-k_post_install\s*\)" "$0" > /dev/null && exec sh "$0" -k_post_install
        ;;


        -k_post_install)
            . "/opt/sbin/.xkeen/import.sh"
            init_directories
            xkeen_info
