                "$initd_file" restart on >/dev/null 2>&1
            fi

            delete_tmp

            echo
            echo -e "  Переустановка XKeen ${green}выполнена${reset}"
        ;;


        -g)    # Установка баз GeoFile
            command -v xray >/dev/null 2>&1 || { echo -e "  ${red}Не обнаружено${reset} ядро проксирования Xray"; exit 1; }
            test_connection
