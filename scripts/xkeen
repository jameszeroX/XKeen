            acquire_lock
            clear
            echo
            choice_for_remove="Mihomo"
            choice_remove
            clear
            echo
            command -v mihomo >/dev/null 2>&1 || { echo -e "  Mihomo ${red}не установлен${reset}"; exit 1; }
            echo -e "  Удаление ${yellow}Mihomo${reset}"

            "$initd_file" stop >/dev/null 2>&1
