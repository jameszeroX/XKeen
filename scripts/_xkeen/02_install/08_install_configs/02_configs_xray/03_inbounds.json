      },
      "sniffing": {
        "enabled": true,
        "routeOnly": true,
        "destOverride": ["http","tls"]
      },
      "tag": "redirect"
    },
    {
      "port": 1181,
      "protocol": "tunnel",
      "settings": {
        "network": "udp",
        "followRedirect": true
      },
      "streamSettings": {
        "sockopt": {"tproxy": "tproxy"}
      },
      "sniffing": {
        "enabled": true,
        "routeOnly": true,
        "destOverride": ["quic"]
      },
      "tag": "tproxy"
    },
    {
      "port": 1191,
      "protocol": "tunnel",
      "settings": {
        "network": "tcp",
        "followRedirect": true
      },
      "tag": "force-proxy-redirect"
    },
    {
      "port": 1191,
      "protocol": "tunnel",
      "settings": {
        "network": "udp",
        "followRedirect": true
      },
      "streamSettings": {
        "sockopt": {"tproxy": "tproxy"}
      },
      "tag": "force-proxy-tproxy"
    }
  ]
